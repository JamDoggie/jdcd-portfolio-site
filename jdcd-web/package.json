{
  "name": "jdcd-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node generate-content.mjs && node generate-thumbnails.mjs && node generate-video-thumbnails.mjs && ng serve",
    "build": "node generate-content.mjs && node generate-thumbnails.mjs && node generate-video-thumbnails.mjs && ng build && node -e \"require('fs').copyFileSync('dist/jdcd-web/browser/index.html','dist/jdcd-web/browser/404.html')\"",
    "watch": "node generate-content.mjs && ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/router": "^21.2.1",
    "angular-three": "^4.0.9",
    "animate.css": "^4.1.1",
    "rxjs": "~7.8.0",
    "three": "^0.182.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.2.1",
    "@types/node": "^20.17.19",
    "@types/three": "^0.183.1",
    "angular-three-plugin": "^4.0.9",
    "dompurify": "^3.3.2",
    "gray-matter": "^4.0.3",
    "jsdom": "^27.1.0",
    "marked": "^17.0.4",
    "puppeteer": "^24.39.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
